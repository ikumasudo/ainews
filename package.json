{
  "name": "ainews",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply ainews --local",
    "db:migrate:remote": "wrangler d1 migrations apply ainews --remote",
    "db:seed:local": "wrangler d1 execute ainews --local --file=seeds/seed.sql",
    "types": "wrangler types"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "hono": "^4.12.4"
  }
}
